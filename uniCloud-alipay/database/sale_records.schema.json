{
  "bsonType": "object",
  "required": ["dog_id", "family_id", "buyer_name", "sale_price", "status"],
  "permission": {
    "read": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "properties": {
    "_id": {
      "description": "销售记录ID"
    },
    "dog_id": {
      "bsonType": "string",
      "foreignKey": "dogs._id",
      "description": "关联犬只ID"
    },
    "dog_name": {
      "bsonType": "string",
      "description": "犬只名称（冗余存储）"
    },
    "family_id": {
      "bsonType": "string",
      "foreignKey": "families._id",
      "description": "所属家庭ID"
    },
    "buyer_name": {
      "bsonType": "string",
      "description": "买家姓名"
    },
    "buyer_phone": {
      "bsonType": "string",
      "description": "买家电话"
    },
    "sale_price": {
      "bsonType": "number",
      "description": "成交价格（元）"
    },
    "deposit_amount": {
      "bsonType": "number",
      "description": "定金金额（元）"
    },
    "status": {
      "bsonType": "string",
      "enum": ["待售", "已预定", "已成交", "已退款", "定金取消"],
      "description": "销售状态"
    },
    "notes": {
      "bsonType": "string",
      "description": "备注"
    },
    "created_by": {
      "bsonType": "string",
      "description": "创建人用户ID"
    },
    "deleted_at": {
      "bsonType": ["number", "null"],
      "description": "软删除时间戳（毫秒），null 表示未删除"
    },
    "created_at": {
      "bsonType": "number",
      "description": "创建时间（时间戳毫秒）"
    },
    "updated_at": {
      "bsonType": "number",
      "description": "更新时间（时间戳毫秒）"
    }
  }
}
