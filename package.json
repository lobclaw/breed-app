{
  "name": "breed-app",
  "version": "0.1.0",
  "private": true,
  "description": "犬类繁育管理工具",
  "scripts": {
    "dev:app": "uni -p app",
    "dev:h5": "uni",
    "dev:mp-alipay": "uni -p mp-alipay",
    "build:app": "uni build -p app",
    "build:h5": "uni build",
    "build:mp-alipay": "uni build -p mp-alipay",
    "graphify:worksets": "./scripts/graphify-workset.sh list",
    "graphify:workset": "./scripts/graphify-workset.sh",
    "graphify:suggest": "./scripts/graphify-workset.sh suggest",
    "graphify:auto": "./scripts/graphify-workset.sh auto",
    "graphify:auto-build": "./scripts/graphify-workset.sh auto-build",
    "graphify:start": "./scripts/graphify-start.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4080420251103001",
    "@dcloudio/uni-app-plus": "3.0.0-4080420251103001",
    "@dcloudio/uni-components": "3.0.0-4080420251103001",
    "@dcloudio/uni-h5": "3.0.0-4080420251103001",
    "@dcloudio/uni-mp-alipay": "3.0.0-4080420251103001",
    "pinia": "^2.1.7",
    "pinia-plugin-unistorage": "^0.1.2",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4080420251103001",
    "@dcloudio/uni-cli-shared": "3.0.0-4080420251103001",
    "@dcloudio/uni-stacktracey": "3.0.0-4080420251103001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4080420251103001",
    "@esbuild/darwin-x64": "^0.20.2",
    "@rollup/rollup-darwin-x64": "^4.60.0",
    "@vue/runtime-core": "^3.4.21",
    "@vue/tsconfig": "^0.1.3",
    "sass": "^1.98.0",
    "typescript": "^4.9.4",
    "vite": "5.2.8",
    "vitest": "^1.6.0",
    "vue-tsc": "^1.0.24"
  }
